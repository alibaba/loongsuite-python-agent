### 场景 4: 流式响应

**wrapper 实现**：
```python
import inspect
from typing import AsyncIterator, Iterator

def wrapper(wrapped, instance, args, kwargs):
    result = wrapped(*args, **kwargs)
    
    # 检测同步生成器
    if inspect.isgenerator(result):
        return _wrap_sync_generator(result)
    
    # 检测异步生成器
    if inspect.isasyncgen(result):
        return _wrap_async_generator(result)
    
    return result


def _wrap_sync_generator(generator: Iterator):
    """Wrap synchronous generator"""
    try:
        for chunk in generator:
            print(f"[INSTRUMENTATION] Stream chunk: {type(chunk)}")
            yield chunk
    finally:
        print(f"[INSTRUMENTATION] Stream completed")


async def _wrap_async_generator(generator: AsyncIterator):
    """Wrap asynchronous generator"""
    try:
        async for chunk in generator:
            print(f"[INSTRUMENTATION] Async stream chunk: {type(chunk)}")
            yield chunk
    finally:
        print(f"[INSTRUMENTATION] Async stream completed")
```

