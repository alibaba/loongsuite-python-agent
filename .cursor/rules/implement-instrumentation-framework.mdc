### 阶段 3: 实现 Instrumentor 框架

**目标**：实现基本的 Instrumentor，能够正确 patch 目标方法

#### 3.1 实现 __init__.py

**参考**：
- LongSuite 已有插件：[@loongsuite-instrumentation-agentscope](mdc:instrumentation-loongsuite/loongsuite-instrumentation-agentscope)
- 上游参考：[@opentelemetry-instrumentation-openai-v2/__init__.py](mdc:instrumentation-genai/opentelemetry-instrumentation-openai-v2/src/opentelemetry/instrumentation/openai_v2/__init__.py)

**基本结构**：
```python
"""LongSuite [框架名称] instrumentation"""

from typing import Collection
from wrapt import wrap_function_wrapper

from opentelemetry.instrumentation.instrumentor import BaseInstrumentor
from opentelemetry.instrumentation.utils import unwrap
from loongsuite.instrumentation.[框架名称].package import _instruments
from loongsuite.instrumentation.[框架名称].version import __version__

# 导入 wrapper 函数
from loongsuite.instrumentation.[框架名称].patch import (
    wrap_[方法名称],
)


class [框架名称]Instrumentor(BaseInstrumentor):
    """An instrumentor for [框架名称]"""

    def instrumentation_dependencies(self) -> Collection[str]:
        return _instruments

    def _instrument(self, **kwargs):
        """Instrument the [框架名称] library"""
        tracer_provider = kwargs.get("tracer_provider")
        
        # Patch 点位 1: 同步方法
        wrap_function_wrapper(
            "[框架包名].[模块]",
            "[类名].[方法名]",
            wrap_[方法名称](tracer_provider),
        )
        
        # Patch 点位 2: 异步方法（如果有）
        wrap_function_wrapper(
            "[框架包名].[模块]",
            "[异步类名].[方法名]",
            wrap_[方法名称](tracer_provider, is_async=True),
        )

    def _uninstrument(self, **kwargs):
        """Uninstrument the [框架名称] library"""
        # pylint: disable=import-outside-toplevel
        import [框架包名].[模块]
        
        # 使用 OpenTelemetry 提供的 unwrap 工具函数
        from opentelemetry.instrumentation.utils import unwrap
        
        # 为每个被 patch 的点位调用 unwrap
        unwrap([框架包名].[模块].[类名], "[方法名]")
        unwrap([框架包名].[模块].[异步类名], "[方法名]")
```

**注意**：
- 命名空间使用 `loongsuite.instrumentation.[框架名称]`
- docstring 中使用 "LongSuite" 而不是 "OpenTelemetry"
- **必须使用** `opentelemetry.instrumentation.utils.unwrap` 来解除 patch
- **不要依赖** wrapt 的自动恢复，必须显式调用 unwrap
- import 使用 `# pylint: disable=import-outside-toplevel` 避免循环依赖

#### 3.2 实现 patch.py

**关键点**：
- 初期只打印日志，不提取数据
- 处理同步和异步
- 处理流式和非流式（如需要）

**同步方法的 wrapper**：
```python
"""Patch functions for [框架名称] instrumentation"""

from wrapt import wrap_function_wrapper
import functools


def wrap_[方法名称](tracer_provider, is_async=False):
    """Wrap the [方法名称] method"""
    
    def wrapper(wrapped, instance, args, kwargs):
        """Wrapper function for sync calls"""
        print(f"[INSTRUMENTATION] Entering {wrapped.__module__}.{wrapped.__qualname__}")
        print(f"[INSTRUMENTATION] Args: {args[:2] if len(args) > 2 else args}")  # 只打印前几个参数
        print(f"[INSTRUMENTATION] Kwargs keys: {list(kwargs.keys())}")
        
        try:
            result = wrapped(*args, **kwargs)
            print(f"[INSTRUMENTATION] Call successful, result type: {type(result)}")
            return result
        except Exception as e:
            print(f"[INSTRUMENTATION] Call failed: {e}")
            raise
        finally:
            print(f"[INSTRUMENTATION] Exiting {wrapped.__module__}.{wrapped.__qualname__}")
    
    async def async_wrapper(wrapped, instance, args, kwargs):
        """Wrapper function for async calls"""
        print(f"[INSTRUMENTATION] [ASYNC] Entering {wrapped.__module__}.{wrapped.__qualname__}")
        print(f"[INSTRUMENTATION] [ASYNC] Args: {args[:2] if len(args) > 2 else args}")
        print(f"[INSTRUMENTATION] [ASYNC] Kwargs keys: {list(kwargs.keys())}")
        
        try:
            result = await wrapped(*args, **kwargs)
            print(f"[INSTRUMENTATION] [ASYNC] Call successful, result type: {type(result)}")
            return result
        except Exception as e:
            print(f"[INSTRUMENTATION] [ASYNC] Call failed: {e}")
            raise
        finally:
            print(f"[INSTRUMENTATION] [ASYNC] Exiting {wrapped.__module__}.{wrapped.__qualname__}")
    
    return async_wrapper if is_async else wrapper
```

**处理生成器/流式响应**：
```python
def wrapper(wrapped, instance, args, kwargs):
    """Wrapper with generator handling"""
    print(f"[INSTRUMENTATION] Entering {wrapped.__module__}.{wrapped.__qualname__}")
    
    result = wrapped(*args, **kwargs)
    
    # 检查是否是生成器
    import inspect
    if inspect.isgenerator(result):
        print(f"[INSTRUMENTATION] Detected generator response")
        return _wrap_generator(result, wrapped)
    else:
        print(f"[INSTRUMENTATION] Non-streaming response")
        return result


def _wrap_generator(generator, wrapped):
    """Wrap a generator to log events"""
    try:
        for chunk in generator:
            print(f"[INSTRUMENTATION] Generator yielded chunk: {type(chunk)}")
            yield chunk
    finally:
        print(f"[INSTRUMENTATION] Generator completed")
```

